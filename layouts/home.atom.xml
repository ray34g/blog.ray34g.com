{{- $feedConfig := site.Params.feed | default dict -}}
{{- $sections := index $feedConfig "sections" | default (slice "posts") -}}
{{- $limit := index $feedConfig "limit" | default 20 -}}
{{- $pages := where site.RegularPages "Section" "in" $sections -}}
{{- $pages = first $limit $pages.ByLastmod.Reverse -}}
{{- $feedURL := "" -}}
{{- with .OutputFormats.Get "Atom" -}}
  {{- $feedURL = .Permalink -}}
{{- end -}}
{{- $updated := .Lastmod -}}
{{- with index $pages 0 -}}
  {{- $updated = .Lastmod -}}
{{- end -}}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.Language.Locale | default site.Language.Lang }}">
  <title>{{ site.Title | transform.XMLEscape }}</title>
  <id>{{ $feedURL | transform.XMLEscape }}</id>
  <link href="{{ $feedURL | transform.XMLEscape }}" rel="self" type="application/atom+xml"/>
  <link href="{{ .Permalink | transform.XMLEscape }}" rel="alternate" type="text/html"/>
  <updated>{{ $updated.UTC.Format "2006-01-02T15:04:05Z07:00" }}</updated>
  <author>
    <name>{{ site.Params.author | default site.Title | transform.XMLEscape }}</name>
  </author>
  <generator uri="https://gohugo.io/">Hugo</generator>
  {{- range $pages }}
  <entry>
    <title>{{ .Title | transform.XMLEscape }}</title>
    <id>{{ .Permalink | transform.XMLEscape }}</id>
    <link href="{{ .Permalink | transform.XMLEscape }}" rel="alternate" type="text/html"/>
    <published>{{ .Date.UTC.Format "2006-01-02T15:04:05Z07:00" }}</published>
    <updated>{{ .Lastmod.UTC.Format "2006-01-02T15:04:05Z07:00" }}</updated>
    {{- with .Description | default .Summary | plainify }}
    <summary>{{ . | transform.XMLEscape }}</summary>
    {{- end }}
  </entry>
  {{- end }}
</feed>
